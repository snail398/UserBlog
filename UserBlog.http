### Register user
POST {{UserBlog_HostAddress}}/api/auth/register
Content-Type: application/json
Accept: application/json

{
  "email": "user@example.com",
  "username": "user",
  "password": "Password123!"
}

### Register user - validation error
POST {{UserBlog_HostAddress}}/api/auth/register
Content-Type: application/json
Accept: application/json

{
  "email": "bad-email",
  "username": "jo",
  "password": "123"
}

### Login user
POST {{UserBlog_HostAddress}}/api/auth/login
Content-Type: application/json
Accept: application/json

{
  "email": "user@example.com",
  "password": "Password123!"
}

### Login user - invalid credentials
POST {{UserBlog_HostAddress}}/api/auth/login
Content-Type: application/json
Accept: application/json

{
  "email": "user@example.com",
  "password": "WrongPassword123!"
}

### Get current user
GET {{UserBlog_HostAddress}}/api/users/me
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Refresh tokens
POST {{UserBlog_HostAddress}}/api/auth/refresh
Content-Type: application/json
Accept: application/json

{
  "refreshToken": "{{RefreshToken}}"
}

### Logout
POST {{UserBlog_HostAddress}}/api/auth/logout
Content-Type: application/json
Accept: application/json

{
  "refreshToken": "{{RefreshToken}}"
}



### Create draft post
POST {{UserBlog_HostAddress}}/api/posts
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{AccessToken}}

{
  "title": "My first post",
  "content": "Hello world from UserBlog",
  "status": "Draft"
}

### Create published post
POST {{UserBlog_HostAddress}}/api/posts
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{AccessToken}}

{
  "title": "My published post",
  "content": "This post is visible to everyone.",
  "status": "Published"
}

### Create post - validation error
POST {{UserBlog_HostAddress}}/api/posts
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{AccessToken}}

{
  "title": "",
  "content": "",
  "status": "Draft"
}

### Get public posts
GET {{UserBlog_HostAddress}}/api/posts
Accept: application/json

### Get public posts with pagination
GET {{UserBlog_HostAddress}}/api/posts?page=1&pageSize=10
Accept: application/json

### Search public posts
GET {{UserBlog_HostAddress}}/api/posts?page=1&pageSize=10&search=published
Accept: application/json

### Get public posts - validation error
GET {{UserBlog_HostAddress}}/api/posts?page=0&pageSize=500
Accept: application/json

### Get post by id
GET {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Accept: application/json

### Get post by id as authenticated user
GET {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Get post by id - not found
GET {{UserBlog_HostAddress}}/api/posts/00000000-0000-0000-0000-000000000000
Accept: application/json

### Get my posts
GET {{UserBlog_HostAddress}}/api/me/posts
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Get my draft posts
GET {{UserBlog_HostAddress}}/api/me/posts?page=1&pageSize=10&status=Draft
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Get my published posts
GET {{UserBlog_HostAddress}}/api/me/posts?page=1&pageSize=10&status=Published
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Search my posts
GET {{UserBlog_HostAddress}}/api/me/posts?page=1&pageSize=10&search=first
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Get my posts - unauthorized
GET {{UserBlog_HostAddress}}/api/me/posts
Accept: application/json

### Update post
PATCH {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{AccessToken}}

{
  "title": "Updated post title",
  "content": "Updated post content"
}

### Update post title only
PATCH {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{AccessToken}}

{
  "title": "Only title updated"
}

### Update post - validation error
PATCH {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{AccessToken}}

{
  "title": "",
  "content": ""
}

### Update post - unauthorized
PATCH {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Content-Type: application/json
Accept: application/json

{
  "title": "Should not work"
}

### Delete post
DELETE {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Delete post - unauthorized
DELETE {{UserBlog_HostAddress}}/api/posts/{{PostId}}
Accept: application/json

### Delete post - not found
DELETE {{UserBlog_HostAddress}}/api/posts/00000000-0000-0000-0000-000000000000
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Publish post
POST {{UserBlog_HostAddress}}/api/posts/{{PostId}}/publish
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Unpublish post
POST {{UserBlog_HostAddress}}/api/posts/{{PostId}}/unpublish
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Publish post - unauthorized
POST {{UserBlog_HostAddress}}/api/posts/{{PostId}}/publish
Accept: application/json
